DATABASE_URL=postgresql://user:password@host:5432/beeforest
JWT_SECRET=change-me-to-a-long-random-string
CORS_ORIGIN=https://your-app.vercel.app
PORT=3001
NODE_ENV=production

# Cloudflare R2 — required for audio uploads (instructions/responses)
# Create bucket at dash.cloudflare.com → R2 → Create bucket
# Generate API token at R2 → Manage API tokens → Create token
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=bee-forest-audio
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXX.r2.dev

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@yourdomain.com

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
