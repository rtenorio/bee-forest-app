    "db:seed-hives": "tsx src/db/seed_hives.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@sentry/node": "^10.47.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "pg": "^8.13.3",
    "twilio": "^5.13.1",
    "uuid": "^11.0.5",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
